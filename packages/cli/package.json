{
  "name": "@memcode/cli",
  "version": "1.0.7",
  "description": "CLI for MemCode Project Memory Assistant",
  "keywords": [
    "memory",
    "cli",
    "project-memory",
    "coding-assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scalenation/memcode.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/scalenation/memcode#readme",
  "bugs": {
    "url": "https://github.com/scalenation/memcode/issues"
  },
  "bin": {
    "memory": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js && chmod +x dist/scripts/postinstall.js",
    "prepublishOnly": "pnpm build && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "clean": "rm -rf dist",
    "postinstall": "node dist/scripts/postinstall.js || true"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@memcode/cloud-client": "workspace:*",
    "@memcode/core": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.15.0"
  }
}
