{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/v1/admin/brain/compact",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/health",    "destination": "/api/index" },
    { "source": "/v1/(.*)",   "destination": "/api/index" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/login",     "destination": "/login.html" },
    { "source": "/privacy",   "destination": "/privacy.html" }
  ],
  "env": {
    "SERVE_STATIC": "false"
  }
}
